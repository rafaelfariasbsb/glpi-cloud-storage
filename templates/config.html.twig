{% import 'components/form/fields_macros.html.twig' as fields %}

{% set field_options = { 'full_width': true } %}

<form method="POST" action="config.form.php" data-track-changes="true">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />

    <div class="row">
        {{ fields.largeTitle(__('General'), 'ti ti-settings', true) }}

        {{ fields.dropdownYesNo(
            'enabled',
            config['enabled'] ?? '0',
            __('Enabled'),
            field_options
        ) }}

        {{ fields.dropdownArrayField(
            'provider',
            config['provider'] ?? 'azure',
            {
                'azure': __('Azure Blob Storage'),
            },
            __('Storage Provider'),
            field_options|merge({
                'helper': __('Cloud storage provider to use for document storage'),
            })
        ) }}

        {{ fields.largeTitle(__('Azure Connection'), 'ti ti-plug') }}

        <div id="azure-fields">
            {{ fields.textField(
                'azure_account_name',
                config['azure_account_name'] ?? '',
                __('Account Name'),
                field_options|merge({
                    'helper': __('Azure Storage Account name (e.g. myaccount)'),
                })
            ) }}

            {{ fields.passwordField(
                'azure_connection_string',
                config['azure_connection_string'] ?? '',
                __('Connection String'),
                field_options|merge({
                    'clearable': true,
                    'helper': __('Full Azure Storage connection string'),
                })
            ) }}

            {{ fields.passwordField(
                'azure_account_key',
                config['azure_account_key'] ?? '',
                __('Account Key'),
                field_options|merge({
                    'clearable': true,
                    'helper': __('Azure Storage Account access key'),
                })
            ) }}

            {{ fields.textField(
                'azure_container_name',
                config['azure_container_name'] ?? 'glpi-documents',
                __('Container Name'),
                field_options|merge({
                    'helper': __('Blob container name where documents will be stored'),
                })
            ) }}
        </div>

        {{ fields.largeTitle(__('Storage Behavior'), 'ti ti-settings') }}

        {{ fields.dropdownArrayField(
            'storage_mode',
            config['storage_mode'] ?? 'cloud_primary',
            {
                'cloud_primary': __('Cloud Primary - Delete local copy after upload'),
                'cloud_backup': __('Cloud Backup - Keep both local and cloud copies'),
            },
            __('Storage Mode'),
            field_options|merge({
                'helper': __('Controls whether local files are kept after upload to cloud storage'),
            })
        ) }}

        {{ fields.dropdownArrayField(
            'download_method',
            config['download_method'] ?? 'redirect',
            {
                'redirect': __('Redirect - Redirect browser to temporary cloud URL'),
                'proxy': __('Proxy - Stream through GLPI server'),
            },
            __('Download Method'),
            field_options|merge({
                'helper': __('How documents are served to users when downloading'),
            })
        ) }}

        {{ fields.numberField(
            'url_expiry_minutes',
            config['url_expiry_minutes'] ?? '5',
            __('URL Expiry (minutes)'),
            field_options|merge({
                'min': 1,
                'max': 1440,
                'step': 1,
                'helper': __('How long temporary URLs remain valid (only for Redirect mode)'),
            })
        ) }}
    </div>

    <div class="card-footer mx-n2 mb-n2 d-flex">
        <button type="submit" name="test_connection" class="btn btn-outline-secondary">
            <i class="ti ti-plug me-1"></i>
            <span>{{ __('Test Connection') }}</span>
        </button>
        {% if canedit %}
            <button type="submit" name="update" value="1" class="ms-auto btn btn-primary">
                <i class="ti ti-device-floppy me-1"></i>
                <span>{{ _x('button', 'Save') }}</span>
            </button>
        {% endif %}
    </div>
</form>

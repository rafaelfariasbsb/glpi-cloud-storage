{% import 'components/form/fields_macros.html.twig' as fields %}

{% set field_options = { 'full_width': true } %}

<form method="POST" action="config.form.php" data-track-changes="true">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />

    {{ fields.largeTitle(__('Azure Connection'), 'ti ti-cloud', true) }}

    <div class="row ps-4">
        {{ fields.dropdownYesNo(
            'enabled',
            config['enabled'] ?? '0',
            __('Enabled'),
            field_options
        ) }}

        {{ fields.textField(
            'account_name',
            config['account_name'] ?? '',
            __('Account Name'),
            field_options|merge({
                'helper': __('Azure Storage Account name (e.g. myaccount)'),
            })
        ) }}

        {{ fields.passwordField(
            'connection_string',
            config['connection_string'] ?? '',
            __('Connection String'),
            field_options|merge({
                'clearable': true,
                'helper': __('Full Azure Storage connection string'),
            })
        ) }}

        {{ fields.passwordField(
            'account_key',
            config['account_key'] ?? '',
            __('Account Key'),
            field_options|merge({
                'clearable': true,
                'helper': __('Azure Storage Account access key'),
            })
        ) }}

        {{ fields.textField(
            'container_name',
            config['container_name'] ?? 'glpi-documents',
            __('Container Name'),
            field_options|merge({
                'helper': __('Blob container name where documents will be stored'),
            })
        ) }}
    </div>

    <div class="hr-text">
        <i class="ti ti-settings"></i>
        <span>{{ __('Storage Behavior') }}</span>
    </div>

    <div class="row ps-4">
        {{ fields.dropdownArrayField(
            'storage_mode',
            config['storage_mode'] ?? 'azure_primary',
            {
                'azure_primary': __('Azure Primary - Delete local copy after upload'),
                'azure_backup': __('Azure Backup - Keep both local and Azure copies'),
            },
            __('Storage Mode'),
            field_options|merge({
                'helper': __('Controls whether local files are kept after upload to Azure'),
            })
        ) }}

        {{ fields.dropdownArrayField(
            'download_method',
            config['download_method'] ?? 'sas_redirect',
            {
                'sas_redirect': __('SAS Redirect - Redirect browser to Azure temporary URL'),
                'proxy': __('Proxy - Stream through GLPI server'),
            },
            __('Download Method'),
            field_options|merge({
                'helper': __('How documents are served to users when downloading'),
            })
        ) }}

        {{ fields.numberField(
            'sas_expiry_minutes',
            config['sas_expiry_minutes'] ?? '10',
            __('SAS URL Expiry (minutes)'),
            field_options|merge({
                'min': 1,
                'max': 1440,
                'step': 1,
                'helper': __('How long SAS URLs remain valid (only for SAS Redirect mode)'),
            })
        ) }}
    </div>

    <div class="card-footer mx-n2 mb-n2 d-flex">
        <button type="submit" name="test_connection" class="btn btn-outline-secondary">
            <i class="ti ti-plug me-1"></i>
            <span>{{ __('Test Connection') }}</span>
        </button>
        {% if canedit %}
            <button type="submit" name="update" value="1" class="ms-auto btn btn-primary">
                <i class="ti ti-device-floppy me-1"></i>
                <span>{{ _x('button', 'Save') }}</span>
            </button>
        {% endif %}
    </div>
</form>
